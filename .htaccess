<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /jamify/

  # Jeśli proszą o istniejący plik/katalog → serwuj normalnie
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Wszystko inne kieruj do index.php, zachowując query string
  RewriteRule ^ index.php [L,QSA]
</IfModule>
